#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <Update.h>

// --- Configuration ---
const char* ssid = "YOUR_WIFI_SSID";
const char* password = "YOUR_WIFI_PASSWORD";
String serverUrl = "http://YOUR_SERVER_IP:8000/api/v1"; // Replace YOUR_SERVER_IP

// Device Identity
const char* device_uuid = "esp32-c3-test-dev-01";
const char* device_name = "Laboratory ESP32-C3";
const char* board_type = "ESP32-C3";
const char* current_version = "0.0.1";

// --- Global Objects ---
WiFiClient client;

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n--- ESP32-C3 Test Firmware ---");

  // 1. Connect to Wi-Fi
  connectToWiFi();

  // 2. Register/Update Config with Server
  registerDevice();

  // 3. Check for OTA Updates
  checkForUpdates();
}

void loop() {
  // Main logic placeholder
  // For a test firmware, we might just blink or wait
  Serial.println("Running main loop...");
  delay(5000);
}

void connectToWiFi() {
  Serial.print("Connecting to WiFi: ");
  Serial.println(ssid);
  
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi connected!");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nFailed to connect to WiFi.");
  }
}

void registerDevice() {
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  String url = serverUrl + "/config";
  
  // Construct JSON Payload compatible with server's DeviceConfig model
  StaticJsonDocument<512> doc;
  
  // device
  JsonObject device = doc.createNestedObject("device");
  device["uuid"] = device_uuid;
  device["name"] = device_name;
  device["board"] = board_type;
  device["mode"] = "no-code";
  device["is_authorized"] = true; // Requesting auth
  device["version"] = current_version;
  device["created_at"] = ""; // Optional, handled by server if empty/new
  
  // connectivity
  JsonObject connectivity = doc.createNestedObject("connectivity");
  connectivity["protocol"] = "mqtt";
  connectivity["broker"] = "YOUR_MQTT_BROKER_IP";
  connectivity["port"] = 1883;
  connectivity["secure"] = false;
  
  // hardware_config
  JsonObject hw_config = doc.createNestedObject("hardware_config");
  JsonArray pins = hw_config.createNestedArray("pins");
  // Example pin config
  JsonObject pin1 = pins.createNestedObject();
  pin1["pin"] = 2;
  pin1["mode"] = "OUTPUT";
  pin1["type"] = "DIGITAL";
  pin1["function"] = "LED";
  pin1["label"] = "Onboard LED";
  pin1["init"] = "LOW";

  String requestBody;
  serializeJson(doc, requestBody);

  Serial.println("Sending Config to Server: " + url);
  
  http.begin(url);
  http.addHeader("Content-Type", "application/json");
  
  int httpResponseCode = http.POST(requestBody);
  
  if (httpResponseCode > 0) {
    String response = http.getString();
    Serial.println("Response Code: " + String(httpResponseCode));
    Serial.println("Response: " + response);
  } else {
    Serial.print("Error on sending POST: ");
    Serial.println(httpResponseCode);
  }
  
  http.end();
}

void checkForUpdates() {
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  String url = serverUrl + "/ota/latest/" + board_type;
  
  Serial.println("Checking for updates: " + url);
  
  http.begin(url);
  int httpCode = http.GET();
  
  if (httpCode == 200) {
    String payload = http.getString();
    StaticJsonDocument<200> doc;
    deserializeJson(doc, payload);
    
    const char* new_version = doc["version"];
    String filename = doc["filename"];
    
    Serial.print("Current Version: "); Serial.println(current_version);
    Serial.print("Available Version: "); Serial.println(new_version);
    
    if (strcmp(new_version, current_version) > 0) { // Simple string compare, semantic versioning recommended for prod
      Serial.println("New version available. Validating...");
      performOTA(filename);
    } else {
      Serial.println("Device is up to date.");
    }
  } else {
    Serial.println("Failed to check updates (or no update found). HTTP Code: " + String(httpCode));
  }
  http.end();
}

void performOTA(String filename) {
  HTTPClient http;
  String downloadUrl = serverUrl + "/ota/download/" + filename;
  
  Serial.println("Starting OTA Download: " + downloadUrl);
  
  http.begin(downloadUrl);
  int httpCode = http.GET();
  
  if (httpCode == 200) {
    int contentLength = http.getSize();
    bool canBegin = Update.begin(contentLength);

    if (canBegin) {
      Serial.println("Writing OTA to flash...");
      WiFiClient *stream = http.getStreamPtr();
      size_t written = Update.writeStream(*stream);
      
      if (written == contentLength) {
        Serial.println("Written : " + String(written) + " successfully");
      } else {
        Serial.println("Written only : " + String(written) + "/" + String(contentLength) + ". Retry?");
      }
      
      if (Update.end()) {
        if (Update.isFinished()) {
          Serial.println("OTA Update successfully completed. Rebooting...");
          ESP.restart();
        } else {
          Serial.println("OTA Update not finished? something went wrong!");
        }
      } else {
        Serial.println("Error Occurred. Error #: " + String(Update.getError()));
      }
    } else {
      Serial.println("Not enough space to begin OTA");
    }
  } else {
    Serial.println("Download failed. HTTP Code: " + String(httpCode));
  }
  http.end();
}
