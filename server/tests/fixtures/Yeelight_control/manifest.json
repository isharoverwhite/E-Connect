{
  "manifest_version": "1.0",
  "extension_id": "yeelight_control",
  "name": "Yeelight LAN Lights",
  "version": "1.4.0",
  "author": "Experience",
  "description": "An extensions for controlling Yeelight devices. For E-Connect Ecosystem!",
  "provider": {
    "key": "yeelight",
    "display_name": "Yeelight"
  },
  "package": {
    "runtime": "python",
    "entrypoint": "main.py",
    "hooks": {
      "validate_command": "validate_command",
      "execute_command": "execute_command",
      "probe_state": "probe_state"
    }
  },
  "device_schemas": [
    {
      "schema_id": "yeelight_white_light",
      "name": "Yeelight White Light",
      "default_name": "Yeelight White Light",
      "description": "Power and brightness control for single-tone Yeelight lamps.",
      "display": {
        "card_type": "light",
        "capabilities": [
          "power",
          "brightness"
        ]
      },
      "config_schema": {
        "fields": [
          {
            "key": "ip_address",
            "label": "IP Address",
            "type": "string",
            "required": true
          }
        ]
      }
    },
    {
      "schema_id": "yeelight_ambient_light",
      "name": "Yeelight Ambient Light",
      "default_name": "Yeelight Ambient Light",
      "description": "Brightness plus tunable-white control for tone-adjustable lamps.",
      "display": {
        "card_type": "light",
        "capabilities": [
          "power",
          "brightness",
          "color_temperature"
        ],
        "temperature_range": {
          "min": 1700,
          "max": 6500
        }
      },
      "config_schema": {
        "fields": [
          {
            "key": "ip_address",
            "label": "IP Address",
            "type": "string",
            "required": true
          }
        ]
      }
    },
    {
      "schema_id": "yeelight_color_light",
      "name": "Yeelight Color Light",
      "default_name": "Yeelight Color Light",
      "description": "Brightness, RGB, and tunable-white control for common color-capable Yeelight lamps.",
      "display": {
        "card_type": "light",
        "capabilities": [
          "power",
          "brightness",
          "rgb",
          "color_temperature"
        ],
        "temperature_range": {
          "min": 1700,
          "max": 6500
        }
      },
      "config_schema": {
        "fields": [
          {
            "key": "ip_address",
            "label": "IP Address",
            "type": "string",
            "required": true
          }
        ]
      }
    },
    {
      "schema_id": "yeelight_full_spectrum_light",
      "name": "Yeelight Full Spectrum Light",
      "default_name": "Yeelight Full Spectrum Light",
      "description": "Brightness, RGB, and tunable-white control for full-spectrum lamps.",
      "display": {
        "card_type": "light",
        "capabilities": [
          "power",
          "brightness",
          "rgb",
          "color_temperature"
        ],
        "temperature_range": {
          "min": 1700,
          "max": 6500
        }
      },
      "config_schema": {
        "fields": [
          {
            "key": "ip_address",
            "label": "IP Address",
            "type": "string",
            "required": true
          }
        ]
      }
    }
  ]
}
